rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all rule for other paths in database
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper check to verify if the user is signed in (Admin)
    function isSignedIn() {
      return request.auth != null;
    }
    
    // 1. Appointments collection
    match /appointments/{appointmentId} {
      
      allow get: if isSignedIn() || (resource != null && resource.data.refCode == appointmentId);
      allow list: if isSignedIn() || (request.query.filters.refCode != null);
      
      allow create: if true;
      
      // ลูกค้า (ไม่ login): อัปเดตได้เฉพาะ field ที่เกี่ยวข้องกับ 
      // การเลือกคิว / ขอเลื่อน / ขอยกเลิก / บันทึก timeline เท่านั้น
      // Admin (login แล้ว): แก้ไขได้ทุก field
      allow update: if isSignedIn() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'selectedSlot', 'updatedAt', 
          'rescheduleReason', 'cancellationReason', 
          'requestedNewDate', 'requestedNewStartTime', 'requestedNewEndTime', 'requestedNewTimeSlot',
          'timeline',
          'rescheduleType', 'rescheduleContext', 
          'proposedRescheduleDates', 'rescheduleRangeDateFrom', 'rescheduleRangeDateTo',
          'confirmedDate', 'confirmedTime', 'date', 'timeSlot',
          'adminNotes', 'clientSelectedAt', 'cancellationRequestedAt'
        ])
        && (
          !('status' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.status in [
            'client_selected', 'cancellation_requested', 'reschedule_requested', 'confirmed_reschedule'
          ]
        )
      );
      
      allow delete: if isSignedIn();
    }
    
    // 2. Executive Slots collection
    match /executive_slots/{slotId} {
      allow read, write: if isSignedIn();
    }
    
    // 3. Config collection
    match /config/{configId} {
      allow read, write: if isSignedIn();
    }

    // Settings collection
    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }
  }
}